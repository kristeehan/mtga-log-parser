{
  "name": "mtga-log-parser",
  "version": "4.1.0",
  "description": "Parse MTGA (Magic: The Gathering Arena) log files into structured match, game snapshot, and board state data.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "lint": "biome check src",
    "lint:fix": "biome check --write --unsafe src"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kristeehan/mtga-log-parser.git"
  },
  "keywords": [
    "mtga",
    "magic-the-gathering",
    "arena",
    "log-parser"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.0.0",
    "typescript": "~5.7.0",
    "vitest": "^2.1.9"
  }
}
